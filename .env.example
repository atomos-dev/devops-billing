# DevOps Billing System - Environment Variables

# Database
DATABASE_URL=./data/billing.db

# Authentication
AUTH_SECRET=change-me-to-a-random-string
AUTH_USER=admin
AUTH_PASSWORD=change-me

# AWS Configuration
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
# Comma-separated list of regions for resource info collection
AWS_RESOURCE_REGIONS=us-east-1,ap-southeast-1,us-west-2,ap-east-1,ap-northeast-1

# DigitalOcean Configuration
DO_API_TOKEN=

# Provider toggles
AWS_ENABLED=true
DO_ENABLED=true

# Sync Configuration
SYNC_CRON_SCHEDULE=0 6 * * *
SYNC_BACKFILL_MONTHS=6
