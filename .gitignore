# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.key
*.p12
*.pfx
*.jks
*.keystore
*.crt
*.cer
*.kubeconfig
id_rsa
id_ed25519
*.ovpn
*.tfvars
*.tfstate
*.tfstate.*

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files and local secret overrides
.env
.env.*
.envrc
!.env.example
!.env.sample

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# runtime data — exclude SQLite DB and browser session state, keep CSV bills
/data/browser-state/
/data/backups/
/data/*.db
/data/*.db-shm
/data/*.db-wal
/data/*.db-journal

# local database files
*.sqlite
*.sqlite3

# Playwright artifacts can contain screenshots, traces, and auth/session data
/playwright-report/
/test-results/
/blob-report/
*.trace.zip
*.har
